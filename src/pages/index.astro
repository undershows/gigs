---
const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL;
const ASSETS_URL = import.meta.env.PUBLIC_ASSETS_URL || "https://media.undershows.com.br";

const states = [
  "SP", "AC", "AL", "AM", "AP", "BA", "CE", "DF", "ES",
  "GO", "MA", "MG", "MS", "MT", "PA", "PB", "PE", "PI",
  "PR", "RJ", "RN", "RO", "RR", "RS", "SC", "SE", "TO"
];

const today = new Date();
today.setHours(0, 0, 0, 0);

function toYMD(d) {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${y}-${m}-${day}`;
}

function parseLocalDate(dateStr) {
  const [y, m, d] = String(dateStr).split("-").map(Number);
  return new Date(y, m - 1, d);
}

async function fetchUpcomingShows({ pageSize = 300 } = {}) {
  const all = [];
  let page = 1;

  const minDate = toYMD(today);

  while (true) {
    const url =
      `${STRAPI_URL}/api/shows` +
      `?sort[0]=date:asc&sort[1]=id:asc` +
      `&filters[date][$gte]=${encodeURIComponent(minDate)}` +
      `&pagination[page]=${page}` +
      `&pagination[pageSize]=${pageSize}` +
      `&populate=poster`;

    const res = await fetch(url);
    if (!res.ok) throw new Error(`Strapi ${res.status}`);

    const json = await res.json();
    const data = json?.data ?? [];

    all.push(...data);

    if (data.length < pageSize) break;

    page++;
  }

  return all;
}

const allShows = await fetchUpcomingShows({ pageSize: 100 });

const shows = allShows.filter((show) => {
  const d = parseLocalDate(show.date);
  return d >= today;
});

function getPosterUrl(show) {
  const posterRaw = show.poster;
  if (!posterRaw) return null;

  const poster = posterRaw?.data?.attributes || posterRaw;
  if (!poster) return null;

  const url =
    poster.formats?.medium?.url ||
    poster.formats?.large?.url ||
    poster.url;

  if (!url) return null;

  return url.startsWith("http") ? url : `${ASSETS_URL}${url}`;
}

function formatDate(dateStr) {
  const d = parseLocalDate(dateStr);
  return d.toLocaleDateString("pt-BR", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
  });
}

function slugify(name) {
  return name
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function getBands(show) {
  const raw = show.bands || "";
  return raw
    .split(",")
    .map((b) => b.trim())
    .filter(Boolean);
}
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Undershows</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/images/icons/icon-180x180.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/images/icons/icon-192x192-v2.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/images/icons/icon-512x512-v2.png">
    <link rel="manifest" href="/manifest.json">

    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Undershows">
    <meta name="apple-mobile-web-app-status-bar-style" content="black">

    <link rel="preload" as="image" href="https://media.undershows.com.br/logo-undershows.webp" />

    <style>
      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        min-height: 100%;
        background: radial-gradient(ellipse at center, #f05291, gray);
        background-color: #f05291;
        overscroll-behavior-y: none;
      }

      body {
        font-family: system-ui, sans-serif;
        color: #000;
        display: flex;
        justify-content: center;
      }

      a { text-decoration: none; }
      main {
        width: 100%;
        max-width: 900px;
        padding: 24px 16px 48px;
        text-align: center;
      }

      .shop-callout {
        margin: 0 0 4px;
        font-size: 0.9rem;
        font-weight: 700;
        color: #000;
        opacity: 0.9;

        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
      }

      .vinyl-icon {
        width: 16px;
        height: 16px;
        object-fit: contain;
      }
      .logo {
        width: 180px;
        height: 180px;
        max-width: 50vw;
        margin: 12px auto 32px;
        display: block;
        object-fit: contain;
      }

      .states-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
        margin: 0 auto 28px;
        max-width: 380px;
      }

      .state-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 36px;
        border-radius: 8px;
        border: 2px solid #ff7da8;
        background: #ff4b92;
        color: #000;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
        transition: transform 0.1s ease, box-shadow 0.1s ease;
        box-shadow: 0 2px 0 rgba(0,0,0,0.25);
      }

      .state-btn--active {
        background: #ff4b92;
        border-color: #000;
        border-width: 3px;
        font-weight: 800;
      }

      .state-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 0 rgba(0,0,0,0.4);
      }

      @media (min-width: 600px) {
        .states-grid { max-width: 480px; gap: 8px; margin-bottom: 24px; }
        .state-btn { width: 56px; height: 36px; font-size: 0.9rem; }
      }

      .search-input {
        width: 100%;
        padding: 12px 20px;
        border: 2px solid rgba(255, 255, 255, 0.8);
        border-radius: 999px;
        text-align: center;
        font-size: 1rem;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.2);
        color: #000;
        outline: none;
        transition: border-color 0.2s ease, background 0.2s ease;
      }

      .search-input:focus {
        border-color: #fff;
        background: rgba(255, 255, 255, 0.35);
      }

      #search::placeholder {
        color: rgba(0, 0, 0, 0.85);
        font-weight: 700;
        transition: opacity 0.15s ease-in-out;
      }
      #search:focus::placeholder { opacity: 0; }

      .shows {
        margin-top: 24px;
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      .show-card {
        text-align: center;
        margin: 0 auto;
        max-width: 460px;
      }

      .show-title {
        margin: 0 0 6px;
        font-weight: 800;
        font-size: 1.15rem;
      }

      .show-info {
        margin: 0 0 6px;
        font-size: 0.95rem;
        opacity: 0.9;
      }

      .show-bands { margin: 0 0 12px; font-size: 0.9rem; }

      .show-bands a {
        color: #000;
        font-weight: 700;
        text-decoration: none;
      }
      .show-bands a:hover { text-decoration: underline; }

      .poster-wrapper {
        display: block;
        border-radius: 12px;
        overflow: hidden;
        max-width: 460px;
        margin: 0 auto;
      }

      .show-poster {
        width: 100%;
        display: block;
      }

      .show-actions {
        display: flex;
        flex-direction: column;
        gap: 2px;
        margin-top: 2px;
        border-radius: 12px;
        overflow: hidden;
      }

      .ticket-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 12px 0;
        background: #000;
        color: #f5f5f5;
        font-weight: 800;
        font-size: 0.98rem;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s ease;
      }

      .ticket-btn:hover { background: #222; }
      .ticket-btn .emoji { font-size: 1.1rem; line-height: 1; }

      .box {
        max-width: 520px;
        margin: 20px auto 0;
        background: rgba(255,255,255,0.75);
        border: 3px solid #000;
        border-radius: 14px;
        padding: 16px;
      }

      .footer-text {
        line-height: 1.6;
        font-size: 0.95rem;
      }

      .footer-text p {
        margin: 10px 0;
        font-weight: 700;
        color: #000;
      }

      .footer-text a {
        color: #000;
        font-weight: 800;
        text-decoration: underline;
      }

      .footer-text a:hover { text-decoration: underline; }
    </style>
  </head>

  <body>
    <main>

      <p class="shop-callout">
        <img src="/images/icon-vinil.png" alt="" class="vinyl-icon" />
        Visite nossa loja, clique no logo!
      </p>

      <a
        href="https://undershows.com.br"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Ir para a loja Undershows"
      >
        <picture>
          <source
            srcset="https://media.undershows.com.br/logo-undershows.webp"
            type="image/webp"
          />
          <img
            src="https://media.undershows.com.br/logo-undershows.png"
            alt="Undershows"
            class="logo"
            width="180"
            height="180"
          />
        </picture>
      </a>

      <!-- ESTADOS -->
      <div class="states-grid">
        {states.map((uf) => (
          <a href={`/?state=${uf}`} class="state-btn" data-state={uf}>{uf}</a>
        ))}
      </div>

      <!-- BUSCA -->
      <div style="max-width:340px;margin:0 auto 28px;">
        <input
          id="search"
          type="text"
          placeholder="🔍 Buscar show, banda, data..."
          class="search-input"
        />
      </div>

      <!-- SHOWS -->
      <section class="shows">
        {shows.map((show) => {
          const posterUrl = getPosterUrl(show);
          const hasTicket = !!show.ticket_link;
          const shareUrl = `https://shows.undershows.com.br/cartaz/${show.id}`;

          return (
            <article
              class="show-card"
              data-state={show.state}
              data-bands={show.bands || ""}>

              <h2 class="show-title">{show.title}</h2>
              <p class="show-info">
                {formatDate(show.date)} — {show.city}/{show.state}
              </p>

              {getBands(show).length > 0 && (
                <p class="show-bands">
                  {getBands(show).map((band, idx) => (
                    <>
                      {idx > 0 && " / "}
                      <a href={`/artist/${slugify(band)}`}>{band}</a>
                    </>
                  ))}
                </p>
              )}

              <div class="poster-wrapper">
                {posterUrl && (
                  <img
                    src={posterUrl}
                    alt={show.title}
                    class="show-poster"
                    loading="lazy"
                  />
                )}
              </div>

              <div class="show-actions">
                {hasTicket && (
                  <a
                    class="ticket-btn"
                    href={show.ticket_link}
                    target="_blank"
                  >
                    <span class="emoji">🎟️</span>Comprar Ingressos
                  </a>
                )}

                <button
                  type="button"
                  class="ticket-btn"
                  data-share-show
                  data-title={show.title}
                  data-date={formatDate(show.date)}
                  data-city={show.city}
                  data-state={show.state}
                  data-poster={posterUrl}
                  data-share-url={shareUrl}
                >
                  <span class="emoji">📤</span>Divulgar o rolê
                </button>
              </div>
            </article>
          );
        })}
      </section>

      <div class="box footer-text">
        <p id="no-shows" class="empty" style="display:none;">
          No momento não temos shows cadastrados nesse estado. 😔🎸
        </p>

        <p>
          Você pode enviar o cartaz por e-mail:
          <a href="mailto:undershowsbr@gmail.com">undershowsbr@gmail.com</a>
          ou pelo WhatsApp:
          <a href="https://wa.me/551152862298?text=Oi!%20Quero%20enviar%20um%20cartaz%20de%20show%20para%20a%20Undershows." target="_blank" rel="noopener">
            (11) 5286-2298
          </a>
        </p>

        <p>
          Aliás, se você curte vinil ou CD, dá uma olhadinha na nossa loja virtual:
          <a href="https://undershows.com.br" target="_blank" rel="noopener">
            undershows.com.br
          </a>
        </p>
      </div>
    </main>

    <!-- FILTRO ESTADO + BUSCA -->
    <script>
      (function () {
        const input = document.getElementById("search");

        function norm(str) {
          return (str || "")
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .toLowerCase()
            .trim();
        }

        function aplicarFiltroPorEstado() {
          const params = new URLSearchParams(window.location.search);
          const currentState = params.get("state") || "SP";
          let visible = 0;

          document.querySelectorAll(".show-card").forEach((card) => {
            const uf = card.getAttribute("data-state");

            if (!currentState || uf === currentState) {
              card.style.display = "";
              visible++;
            } else {
              card.style.display = "none";
            }
          });

          const noShows = document.getElementById("no-shows");
          if (noShows) {
            noShows.textContent = "No momento não temos shows cadastrados nesse estado. 😔🎸";
            noShows.style.display = visible === 0 ? "" : "none";
          }
        }

        input.addEventListener("input", function () {
          const term = norm(this.value);
          const noShows = document.getElementById("no-shows");

          if (term === "") {
            aplicarFiltroPorEstado();
            return;
          }

          let visible = 0;

          document.querySelectorAll(".show-card").forEach((card) => {
            const title = norm(card.querySelector(".show-title")?.textContent);
            const info = norm(card.querySelector(".show-info")?.textContent);
            const bands = norm(card.dataset.bands);

            const matches =
              title.includes(term) ||
              info.includes(term) ||
              bands.includes(term);

            if (matches) {
              card.style.display = "";
              visible++;
            } else {
              card.style.display = "none";
            }
          });

          if (noShows) {
            noShows.textContent = "Nenhum show encontrado para essa busca. 😔🎸";
            noShows.style.display = visible === 0 ? "" : "none";
          }
        });

        aplicarFiltroPorEstado();
      })();
    </script>

    <!-- COMPARTILHAR -->
    <script>
      (function () {
        const SITE_URL = "https://shows.undershows.com.br";

        async function shareShowFromButton(btn) {
          const title = btn.dataset.title;
          const date = btn.dataset.date;
          const city = btn.dataset.city;
          const state = btn.dataset.state;
          const shareUrl = btn.dataset.shareUrl || SITE_URL;

          const text =
`${title}
${date} - ${city}/${state}

via Undershows: ${shareUrl}`;

          try {
            if (navigator.share) {
              await navigator.share({ text });
            } else if (navigator.clipboard) {
              const fullText =
`${title}
${date} - ${city}/${state}

Cartaz: ${shareUrl}

via Undershows: ${SITE_URL}`;

              await navigator.clipboard.writeText(fullText);
              alert("Link copiado! Cole no WhatsApp/Instagram 🤘");
            } else {
              alert("Copie e cole:\n\n" + text + "\n\nCartaz: " + shareUrl);
            }
          } catch (err) {
            console.error("Erro ao compartilhar", err);
          }
        }

        document.addEventListener("click", function (ev) {
          const btn = ev.target.closest("[data-share-show]");
          if (!btn) return;
          ev.preventDefault();
          shareShowFromButton(btn);
        });
      })();
    </script>

  </body>
</html>